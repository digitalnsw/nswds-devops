# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# ── Canonical base (synced from nswds-devops) ───────────────────────────────
# Repo-specific ignores go BELOW this block, under a "# repo-specific" heading,
# so the next sync doesn't clobber them (see note in the PR).

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editors
.vscode
.idea

# AI tooling
.claude
.codex
CLAUDE.md
AGENTS.md

# security scan output
snyk-analysis.json
snyk-code-analysis.json

# local scratch (stray stderr redirects, etc.)
*.err
